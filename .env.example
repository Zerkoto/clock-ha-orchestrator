APP_ENV=development
LOG_LEVEL=INFO
SECRET_KEY=change-me
ADMIN_API_KEY=change-me-admin

POSTGRES_PASSWORD=change-me-db-password
DATABASE_URL=postgresql+psycopg://clock_ha:change-me-db-password@postgres:5432/clock_ha

CLOCK_BASE_URL=https://sky-eu1.clock-software.com
CLOCK_API_USER=
CLOCK_API_KEY=
CLOCK_SUBSCRIPTION_ID=
CLOCK_ACCOUNT_ID=
CLOCK_POLL_INTERVAL_SECONDS=300
CLOCK_SYNC_OVERLAP_SECONDS=120
CLOCK_RECONCILIATION_DAYS_PAST=2
CLOCK_RECONCILIATION_DAYS_FUTURE=45
CLOCK_CLIENT_MODE=disabled
CLOCK_FIXTURE_BOOKINGS_PATH=
CLOCK_FIXTURE_ROOMS_PATH=
CLOCK_FIELD_MAPPING_PATH=config/clock.mapping.example.yaml
CLOCK_POLLING_ENABLED=false

# These are intentionally blank until confirmed from the current official Clock docs
# or observed sandbox payloads. Do not fill them by guessing.
CLOCK_BOOKINGS_ENDPOINT_PATH=
CLOCK_ROOMS_ENDPOINT_PATH=
CLOCK_ENDPOINT_DOC_REFERENCE=

MQTT_ENABLED=false
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_USERNAME=clock_ha_orchestrator
MQTT_PASSWORD=change-me-mqtt-password
MQTT_TLS=false
MQTT_TOPIC_PREFIX=hotel/v1
MQTT_CLIENT_ID=clock-ha-orchestrator-local-stay
MQTT_CONNECT_TIMEOUT_SECONDS=10
MQTT_PUBLISH_TIMEOUT_SECONDS=10

POLICY_SCHEDULER_ENABLED=false
POLICY_TICK_SECONDS=60
OUTBOX_WORKER_ENABLED=false
OUTBOX_POLL_SECONDS=5
OUTBOX_BATCH_SIZE=50
OUTBOX_MAX_ATTEMPTS=8
OUTBOX_STALE_PUBLISH_SECONDS=120

ROOM_REGISTRY_PATH=config/rooms.example.yaml
POLICY_PATH=config/policies.example.yaml
